{
  "name": "voice-ui-kit-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "package",
    "docs",
    "examples/*"
  ],
  "dependencies": {
    "@daily-co/daily-js": "^0.85.0",
    "@pipecat-ai/client-js": "^1.5.0",
    "@pipecat-ai/client-react": "^1.3.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tailwindcss/postcss": "^4.1.13",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "postcss-prefix-selector": "^2.1.1",
    "postcss-prefixwrap": "^1.57.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "pnpm --filter=@pipecat-ai/voice-ui-kit build",
    "dev": "pnpm --filter=@pipecat-ai/voice-ui-kit dev",
    "dev:docs": "pnpm --filter=@pipecat-ai/voice-ui-kit-docs dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "package/src/**/*.{ts,tsx}": "eslint --config package/eslint.config.js"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "glob@>=10": ">=10.5.0",
      "koa": ">=2.16.4",
      "minimatch": ">=10.2.3",
      "picomatch": ">=2.3.2",
      "rollup@>=4": ">=4.59.0",
      "tar": ">=7.5.11",
      "yaml": ">=2.8.3",
      "vite@>=6.0.0 <=6.4.0": ">=6.4.1",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": ">=13.2.1",
      "ajv@<6.14.0": "^6.14.0",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "vite@<=6.4.1": ">=6.4.2",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "vite@>=6.0.0 <=6.4.1": ">=6.4.2",
      "next@>=13.0.0 <15.5.15": ">=15.5.15"
    }
  }
}
